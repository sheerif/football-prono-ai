# Copy to .env and set your credentials
APP_USERNAME=admin
APP_PASSWORD=change-moi
API_FOOTBALL_KEY=your_api_key_here
DATABASE_URL=sqlite:///football.db
AUTO_REFRESH_ON_CONNECTION=true
AUTO_REFRESH_CURRENT_ON_CONNECTION=true
AUTO_REFRESH_START_SEASON=2016
AUTO_REFRESH_END_SEASON=2026
AUTO_REFRESH_LEAGUE_IDS=61,39,140,135,78,2
AUTO_REFRESH_RECENT_SEASONS=2
AUTO_REFRESH_INTERVAL_MINUTES=360
AUTO_REFRESH_PAUSE_SECONDS=0.8
AUTO_REFRESH_MAX_RETRIES=3
